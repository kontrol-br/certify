<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net462;net9.0;</TargetFrameworks>
        <Configurations>Debug;Release;</Configurations>
        <AssemblyName>AutoSSL</AssemblyName>
        <OutputType>Exe</OutputType>
        <Platforms>AnyCPU</Platforms>
        <LangVersion>latest</LangVersion>
        <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    </PropertyGroup>
    <PropertyGroup Condition="'$(TargetFramework)' != 'net462'">
        <PublishSingleFile>true</PublishSingleFile>
        <PublishTrimmed>true</PublishTrimmed>
        <SelfContained>true</SelfContained>

    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug' ">

        <Optimize>false</Optimize>
        <OutputPath>bin\Debug\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
        <WarningLevel>4</WarningLevel>
        <CodeAnalysisRuleSet>..\CodeAnalysis.ruleset</CodeAnalysisRuleSet>
        <Prefer32Bit>false</Prefer32Bit>
    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release' ">

        <Optimize>true</Optimize>
        <OutputPath>bin\Release\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
        <WarningLevel>4</WarningLevel>
        <Prefer32Bit>false</Prefer32Bit>

    </PropertyGroup>
    <PropertyGroup>

        <ProjectGuid>{DA0CCD9F-8CBD-4471-93E0-53BCFB6CA25E}</ProjectGuid>
        <OutputType>Exe</OutputType>
        <RootNamespace>AutoSSL.CLI</RootNamespace>
        <AssemblyName>AutoSSL</AssemblyName>
        <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <StartupObject>Certify.CLI.Program</StartupObject>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="icon_cli.ico" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\Certify.Client\Certify.Client.csproj" />
        <ProjectReference Include="..\Certify.Locales\Certify.Locales.csproj" />
        <ProjectReference Include="..\Certify.Models\Certify.Models.csproj" />

        <TrimmerRootAssembly Include="Certify.Models" />
        <TrimmerRootAssembly Include="Certify.Client" />
        <TrimmerRootAssembly Include="Newtonsoft.Json" />
    </ItemGroup>

    <ItemGroup>
        <None Include="App.config" />
        <None Include="app.manifest" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>
</Project>