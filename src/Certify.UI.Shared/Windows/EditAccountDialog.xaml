<Controls:MetroWindow
    x:Class="Certify.UI.Windows.EditAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Certify.UI.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:Certify.Locales;assembly=Certify.Locales"
    Title="{x:Static res:SR.Account_Edit_SectionTitle}"
    Width="590"
    Height="480"
    Background="{DynamicResource MahApps.Brushes.Window.Background}"
    ResizeMode="CanResizeWithGrip"
    TitleCharacterCasing="Normal"
    WindowStartupLocation="CenterOwner"
    WindowTransitionsEnabled="False"
    mc:Ignorable="d">
    <Controls:MetroWindow.LayoutTransform>
        <ScaleTransform x:Name="ApplicationScaleTransform" CenterX="0" CenterY="0" ScaleX="{Binding MainViewModel.UIScaleFactor}" ScaleY="{Binding MainViewModel.UIScaleFactor}" />
    </Controls:MetroWindow.LayoutTransform>
    <DockPanel Margin="8" LastChildFill="False">

        <TabControl
            x:Name="AccountTab"
            Margin="0,0,0,0"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Stretch"
            Controls:TabControlHelper.UnderlineBrush="{DynamicResource MahApps.Brushes.Accent4}"
            Controls:TabControlHelper.Underlined="TabPanel"
            DockPanel.Dock="Top"
            TabStripPlacement="Top">
            <TabItem
                MinWidth="140"
                Controls:HeaderedControlHelper.HeaderFontSize="12"
                Header="Configurações da Conta"
                IsSelected="true">
                <DockPanel Margin="8,0,0,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        DockPanel.Dock="Top"
                        Style="{StaticResource Instructions}"
                        TextWrapping="Wrap"><Run Text="{x:Static res:SR.Account_Edit_Intro}" /><LineBreak /><Run /></TextBlock>
                    <!--  Certificate Authority Preference  -->
                    <StackPanel
                        Margin="0,0,0,8"
                        DockPanel.Dock="Top"
                        Orientation="Horizontal">
                        <Label
                            Width="120"
                            Margin="0,0,8,0"
                            Content="Autoridade Certificadora" />
                        <ComboBox
                            x:Name="CertificateAuthorityList"
                            Width="300"
                            DisplayMemberPath="Title"
                            ItemsSource="{Binding CertificateAuthorities}"
                            SelectedValue="{Binding Item.CertificateAuthorityId}"
                            SelectedValuePath="Id"
                            SelectionChanged="CertificateAuthorityList_SelectionChanged" />
                    </StackPanel>
                    <!--  Certificate Authority Preference  -->

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                        <Label
                            Width="120"
                            Margin="0,0,8,0"
                            VerticalAlignment="Top"
                            Content="{x:Static res:SR.Email_Address}" />
                        <TextBox
                            Width="300"
                            Height="23"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Text="{Binding Item.EmailAddress}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,0,8,0"
                        DockPanel.Dock="Top"
                        Style="{StaticResource Instructions}"
                        TextWrapping="Wrap"><Run Text="{x:Static res:SR.Account_Edit_Intro2}" /></TextBlock>

                    <StackPanel
                        Margin="0,8"
                        VerticalAlignment="Bottom"
                        DockPanel.Dock="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            Width="330"
                            Margin="0,0,0,0"
                            FontWeight="Bold"
                            Style="{StaticResource Instructions}"
                            Text="{x:Static res:SR.Account_Edit_AgreeConditions}"
                            TextWrapping="Wrap" />

                        <CheckBox
                            Margin="12,12,12,12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Content="{x:Static res:SR.Account_Edit_AgreeConfirm}"
                            DockPanel.Dock="Top"
                            IsChecked="{Binding Item.AgreedToTermsAndConditions}" />

                    </StackPanel>

                </DockPanel>
            </TabItem>

            <TabItem
                MinWidth="140"
                Controls:HeaderedControlHelper.HeaderFontSize="12"
                Header="Avançado">
                <ScrollViewer MaxHeight="350">
                    <DockPanel Margin="8,0,8,0">
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Subheading}">Modo &amp; Preferencias</TextBlock>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Style="{StaticResource Instructions}">Se você precisar testar solicitações de certificado sem afetar o limite de taxa da sua autoridade certificadora (CA), pode usar uma conta que emite apenas certificados de teste (staging):</TextBlock>
                            <CheckBox
                                x:Name="IsStagingMode"
                                Margin="4,4,0,4"
                                Content="Usar Modo Staging (Teste)"
                                IsChecked="{Binding Item.IsStaging}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Style="{StaticResource Instructions}">A autoridade pode oferecer uma &quot;cadeia alternativa&quot; usando um certificado raiz diferente:</TextBlock>
                            <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                <Label
                                    Width="120"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Top"
                                    Content="Cadeia CA Preferida" />
                                <TextBox
                                    Width="300"
                                    Height="23"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Controls:TextBoxHelper.Watermark="(optional) e.g. DST Root CA X3"
                                    Text="{Binding Item.PreferredChain}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>


                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubheadingWithMargin}">Ligações com Contas Externas</TextBlock>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Instructions}">Se for exigido pela sua Autoridade Certificadora, você pode fornecer os detalhes de vinculação de conta externa aqui.</TextBlock>


                        <StackPanel
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Horizontal">
                            <Label
                                Width="120"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top"
                                Content="Key Id" />
                            <TextBox
                                Width="300"
                                Height="23"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Text="{Binding Item.EabKeyId}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Horizontal">
                            <Label
                                Width="120"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top"
                                Content="Key (HMAC)" />
                            <PasswordBox
                                x:Name="EabKey"
                                Width="300"
                                Height="23"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Horizontal">
                            <Label
                                Width="120"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top"
                                Content="Chave Algoritmo" />
                            <TextBox
                                Width="300"
                                Height="23"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Controls:TextBoxHelper.Watermark="optional, e.g. HS256 (default), HS384 or HS512"
                                Text="{Binding Item.EabKeyAlgorithm}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubheadingWithMargin}">Importar ou Personalizar Detalhes da Conta</TextBlock>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Instructions}">Se você precisar importar uma conta de outro cliente em vez de registrar uma nova conta com a Autoridade Certificadora (CA), ou se precisar personalizar ou pré-gerar a chave da conta, você pode, opcionalmente, especificar o URI da Conta e/ou a Chave da Conta (chave privada codificada em PEM):</TextBlock>

                        <StackPanel
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Horizontal">
                            <Label
                                Width="120"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top"
                                Content="URI da Conta" />
                            <TextBox
                                x:Name="AccountURI"
                                Width="300"
                                Height="23"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Text="{Binding Item.ImportedAccountURI}"
                                TextWrapping="WrapWithOverflow" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Horizontal">
                            <Label
                                Width="120"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top"
                                Content="Chave da Conta" />
                            <PasswordBox
                                x:Name="AccountKey"
                                Width="300"
                                Height="48"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top" />


                        </StackPanel>
                        <StackPanel
                            x:Name="AccountKeyGen"
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource Instructions}">Para pré-aprovação de conta e outros cenários avançados, você pode, opcionalmente, pré-gerar um par de chaves personalizado para sua conta ACME:</TextBlock>
                            <Button
                                x:Name="AccountKeyGenerate"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left"
                                Click="AccountKeyGenerate_Click"
                                Content="Gerar" />
                        </StackPanel>
                        <StackPanel
                            x:Name="AccountRollover"
                            Margin="0,0,0,4"
                            DockPanel.Dock="Top"
                            Orientation="Vertical">
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubheadingWithMargin}">Troca de Chave da Conta</TextBlock>
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource Instructions}">Você pode, opcionalmente, alterar o par de chaves associado à sua conta ACME:</TextBlock>
                            <Button
                                x:Name="AccountKeyChange"
                                Width="180"
                                Margin="280,0,0,0"
                                Click="AccountKeyChange_Click"
                                Content="Trocar Chave da Conta" />
                        </StackPanel>
                    </DockPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>


        <DockPanel Margin="0,8,0,0" DockPanel.Dock="Bottom">
            <Button
                x:Name="Save"
                Margin="0,0,12,0"
                Click="Save_Click"
                Content="{x:Static res:SR.Register_Contact}"
                DockPanel.Dock="Right" />
            <Button
                x:Name="Cancel"
                Width="100"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                Click="Cancel_Click"
                Content="{x:Static res:SR.Cancel}"
                DockPanel.Dock="Left" />
        </DockPanel>
    </DockPanel>
</Controls:MetroWindow>
