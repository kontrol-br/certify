<UserControl
    x:Class="Certify.UI.Controls.Settings.General"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:clr="clr-namespace:System;assembly=mscorlib"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:Certify.UI.Controls.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:Certify.Locales;assembly=Certify.Locales"
    d:DesignHeight="420.042"
    d:DesignWidth="885.537"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <UserControl.Resources />
    <ScrollViewer Margin="0,0,0,-113" VerticalScrollBarVisibility="Auto">
        <DockPanel Margin="0,8,0,8">
            <TabControl
                x:Name="GeneralSettingsTab"
                Height="auto"
                Margin="0,0,0,0"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Stretch"
                Controls:TabControlHelper.UnderlineBrush="{DynamicResource MahApps.Brushes.Accent4}"
                Controls:TabControlHelper.Underlined="TabPanel"
                DockPanel.Dock="Top"
                TabStripPlacement="Left">
                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Configurações Gerais"
                    IsSelected="true">
                    <StackPanel
                        Margin="16,0,0,0"
                        DockPanel.Dock="Top"
                        Orientation="Vertical">
                        <TextBlock Style="{StaticResource Subheading}">Configurações de Renovação</TextBlock>

                        <DockPanel>

                            <StackPanel
                                Margin="0,0,0,0"
                                DockPanel.Dock="Left"
                                Orientation="Vertical">
                                <Label
                                    Width="180"
                                    HorizontalAlignment="Left"
                                    Content="Modo de renovação" />
                                <Controls:NumericUpDown
                                    x:Name="RenewalIntervalDays"
                                    Width="100"
                                    Margin="8,0,0,4"
                                    HorizontalAlignment="Left"
                                    Interval="1"
                                    Maximum="60"
                                    Minimum="1"
                                    Value="{Binding Prefs.RenewalIntervalDays}" />
                                <RadioButton
                                    x:Name="RenewalIntervalMode_DaysAfterLastRenewal"
                                    Margin="8,0,0,4"
                                    Checked="SettingsUpdated"
                                    Content="Dias após a última renovação"
                                    GroupName="RenewalIntervalMode"
                                    Unchecked="SettingsUpdated" />
                                <RadioButton
                                    x:Name="RenewalIntervalMode_DaysBeforeExpiry"
                                    Margin="8,0,0,4"
                                    Checked="SettingsUpdated"
                                    Content="Dias antes do vencimento"
                                    GroupName="RenewalIntervalMode"
                                    Unchecked="SettingsUpdated" />
                                <RadioButton
                                    x:Name="RenewalIntervalMode_PercentageLifetime"
                                    Margin="8,0,0,4"
                                    Checked="SettingsUpdated"
                                    Content="Porcentagem do Tempo de Vida Decorrido"
                                    GroupName="RenewalIntervalMode"
                                    Unchecked="SettingsUpdated" />
                            </StackPanel>

                            <StackPanel
                                Width="348"
                                Margin="0,0"
                                DockPanel.Dock="Right"
                                Orientation="Vertical">
                                <Label HorizontalAlignment="Left" Content="{x:Static res:SR.Settings_AutoRenewalRequestLimit}" />
                                <Controls:NumericUpDown
                                    x:Name="RenewalMaxRequests"
                                    Width="100"
                                    Margin="4,0,0,0"
                                    HorizontalAlignment="Left"
                                    Interval="1"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="{Binding Prefs.MaxRenewalRequests}" />
                            </StackPanel>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,0" LastChildFill="False">
                            <TextBlock
                                Margin="0,8,0,8"
                                DockPanel.Dock="Top"
                                Style="{StaticResource SubheadingWithMargin}">
                                Outras Configurações
                            </TextBlock>
                            <StackPanel
                                Width="348"
                                Margin="4,0,32,0"
                                DockPanel.Dock="Left"
                                Orientation="Vertical">

                                <CheckBox
                                    x:Name="IgnoreStoppedSites"
                                    Margin="0,4,0,0"
                                    Content="{x:Static res:SR.Settings_IgnoreStoppedSites}"
                                    IsChecked="{Binding Prefs.IgnoreStoppedSites}" />

                                <CheckBox
                                    x:Name="EnableProxyAPICheckbox"
                                    Margin="0,4,0,0"
                                    Content="{x:Static res:SR.Settings_EnableProxyApiForDomainConfig}"
                                    IsChecked="{Binding Prefs.EnableValidationProxyAPI}" />

                                <CheckBox
                                    x:Name="EnableDNSValidationChecks"
                                    Margin="0,4,0,0"
                                    Content="{x:Static res:SR.Settings_EnableDnsValidation}"
                                    IsChecked="{Binding Prefs.EnableDNSValidationChecks}" />

                                <CheckBox
                                    x:Name="EnableHttpChallengeServer"
                                    Margin="0,4,0,0"
                                    Content="{x:Static res:SR.Settings_EnableHttpChallengeServer}"
                                    IsChecked="{Binding Prefs.EnableHttpChallengeServer}" />



                                <CheckBox
                                    x:Name="EnableParallelRenewals"
                                    Margin="0,4,0,0"
                                    Content="Habilitar Renovações Paralelas"
                                    IsChecked="{Binding Prefs.EnableParallelRenewals}" />
                                <CheckBox
                                    x:Name="EnableExternalPlugins"
                                    Margin="0,4,0,0"
                                    Click="EnableExternalPlugins_Click"
                                    Content="Habilitar Carregamento de Plugin Personalizado"
                                    IsChecked="{Binding Prefs.IncludeExternalPlugins}" />

                                <CheckBox
                                    x:Name="EnableStatusReporting"
                                    Margin="0,4,0,0"
                                    Content="{x:Static res:SR.Settings_EnableStatusReporting}"
                                    IsChecked="{Binding Prefs.EnableStatusReporting}" />
                                <CheckBox
                                    x:Name="EnableExternalCertManagers"
                                    Margin="0,4,0,0"
                                    Content="Habilitar Resultados de Gerenciadores de Certificados Externos"
                                    IsChecked="{Binding Prefs.EnableExternalCertManagers}" />
                                <CheckBox
                                    x:Name="UseModernPFXAlgs"
                                    Margin="0,4,0,0"
                                    Content="Habilitar Algoritmo PFX Moderno (compatibilidade OpenSSL 3.0+)"
                                    IsChecked="{Binding Prefs.UseModernPFXAlgs}" />
                                <CheckBox
                                    x:Name="DisableARIChecks"
                                    Margin="0,4,0,0"
                                    Content="Desativar ACME ARI (não usar datas de renovação sugeridas pela AC)"
                                    IsChecked="{Binding Prefs.DisableARIChecks}" />

                            </StackPanel>

                            <!--  Cert Store Options  -->
                            <StackPanel
                                Margin="0,0,32,0"
                                DockPanel.Dock="Left"
                                Orientation="Vertical">
                                <Label Content="Repositório de Certificados" />
                                <StackPanel Margin="8,0,8,0">
                                    <ComboBox x:Name="CertStoreSelector" SelectionChanged="SettingsUpdated">
                                        <ComboBoxItem Name="My">Padrão (My)</ComboBoxItem>
                                        <ComboBoxItem Name="WebHosting">Hospedagem Web</ComboBoxItem>
                                    </ComboBox>

                                </StackPanel>

                                <Label Content="Tipo Padrão de Chave Privada" />
                                <StackPanel Margin="8,0,0,0">
                                    <ComboBox
                                        x:Name="DefaultKeyType"
                                        DisplayMemberPath="Value"
                                        SelectedValue="{Binding Prefs.DefaultKeyType}"
                                        SelectedValuePath="Key" />
                                </StackPanel>
                            </StackPanel>

                            <!--  Cert Cleanup Options  -->
                            <StackPanel
                                Margin="0,0,0,0"
                                DockPanel.Dock="Left"
                                Orientation="Vertical">
                                <Label Content="Limpeza do Repositório de Certificados" />
                                <StackPanel Margin="0,0,0,0">
                                    <RadioButton
                                        x:Name="CertCleanup_None"
                                        Margin="8,0,0,4"
                                        Checked="SettingsUpdated"
                                        Content="Nenhum"
                                        GroupName="CertCleanupMode"
                                        Unchecked="SettingsUpdated" />
                                    <RadioButton
                                        x:Name="CertCleanup_AfterExpiry"
                                        Margin="8,0,0,4"
                                        Checked="SettingsUpdated"
                                        Content="Após Expirar"
                                        GroupName="CertCleanupMode"
                                        Unchecked="SettingsUpdated" />
                                    <RadioButton
                                        x:Name="CertCleanup_AfterRenewal"
                                        Margin="8,0,0,4"
                                        Checked="SettingsUpdated"
                                        Content="Após Renovação"
                                        GroupName="CertCleanupMode"
                                        Unchecked="SettingsUpdated" />

                                    <RadioButton
                                        x:Name="CertCleanup_FullCleanup"
                                        Margin="8,0,0,4"
                                        Checked="SettingsUpdated"
                                        Content="Limpeza Completa Diária"
                                        GroupName="CertCleanupMode"
                                        Unchecked="SettingsUpdated" />

                                </StackPanel>
                            </StackPanel>

                        </DockPanel>
                            <DockPanel LastChildFill="False" Visibility="{Binding Converter={StaticResource FeatureVisibilityConverter}, ConverterParameter='DATA_STORES', Path=Prefs}">
                                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubheadingWithMargin}">Repositório de Dados</TextBlock>
                                <TextBlock
                                    Margin="4,0,0,0"
                                    DockPanel.Dock="Top"
                                    Style="{StaticResource Instructions}">
                                    Por padrão, o sistema armazena a configuração em um conjunto local de bancos de dados SQLite. Repositórios de dados alternativos como PostgreSQL e SQL Server podem ser configurados para suportar instalações maiores.
                                </TextBlock>

                
                                <StackPanel
                                    Margin="0,4"
                                    DockPanel.Dock="Top"
                                    Orientation="Horizontal">

                                    <Button Margin="0,0,0,0" Click="EditDataStores">Gerenciar Repositório de Dados</Button>
                                </StackPanel>

                            </DockPanel>

                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubheadingWithMargin}">Diagnóstico</TextBlock>
                            <TextBlock
                                Margin="4,0,0,0"
                                DockPanel.Dock="Top"
                                Style="{StaticResource Instructions}">
                                Ao iniciar, o aplicativo executa verificações diagnósticas básicas, como espaço em disco da unidade do sistema e hora do sistema, para ajudar a garantir que o sistema continue funcionando normalmente:
                            </TextBlock>

                            <StackPanel
                                Margin="0,4"
                                DockPanel.Dock="Top"
                                Orientation="Horizontal">
                                <Label Content="Servidor NTP para verificação de tempo" />
                                <TextBox
                                    Width="240"
                                    Margin="4,0"
                                    Controls:TextBoxHelper.Watermark="ex.: pool.ntp.org ou deixe em branco para ignorar a verificação."
                                    Text="{Binding Prefs.NtpServer}" />
                                <Button Margin="0,0,0,0" Click="SettingsUpdated">Aplicar</Button>
                            </StackPanel>

                        </DockPanel>

                    </StackPanel>
                </TabItem>

                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Autoridades Certificadoras">
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Style="{StaticResource Subheading}">Configurações da Autoridade Certificadora</TextBlock>
                        <local:CertificateAuthorities />
                    </StackPanel>
                </TabItem>

                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Credenciais salvas">
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Style="{StaticResource Subheading}">Credenciais salvas</TextBlock>
                        <local:Credentials />
                    </StackPanel>

                </TabItem>

                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Importar &amp; Exportar"
                    IsSelected="false"
                    Visibility="{Binding Converter={StaticResource FeatureVisibilityConverter}, ConverterParameter='IMPORT_EXPORT', Path=Prefs}">
                    <StackPanel
                        Margin="16,0"
                        DockPanel.Dock="Top"
                        Orientation="Vertical">
                        <TextBlock Style="{StaticResource Subheading}">Importar &amp; Exportar</TextBlock>
                        <StackPanel Margin="0,8" Orientation="Vertical">
                            <TextBlock Style="{StaticResource Instructions}">Você pode mover certificados gerenciados e suas configurações relacionadas, credenciais e certificados para ou de outra instância:</TextBlock>
                            <Button
                                x:Name="ImportExport"
                                Width="140"
                                HorizontalAlignment="Left"
                                Click="ImportExport_Click">
                                Importar ou Exportar..
                            </Button>
                            <TextBlock Style="{StaticResource SubheadingWithMargin}">Reinstalação de certificados</TextBlock>
                            <TextBlock Style="{StaticResource Instructions}">Em alguns casos você pode querer reaplicar todos os seus certificados às ligações de sites (IIS) etc :</TextBlock>
                            <CheckBox x:Name="IncludeDeploymentTasks" Margin="0,8,0,8">Executar Todas as Tarefas de Implantação</CheckBox>
                            <Button
                                x:Name="RedeployCertificates"
                                Width="140"
                                HorizontalAlignment="Left"
                                Click="RedeployCertificates_Click">
                                Reinstalar Certificados
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Configurações da Interface"
                    IsSelected="true">
                    <StackPanel Margin="16,0" DockPanel.Dock="Top">
                        <TextBlock Style="{StaticResource Subheading}">Configurações da Interface do Usuário</TextBlock>

                        <StackPanel Margin="0,4" Orientation="Horizontal">
                            <Label Width="100" Content="Idioma" />
                            <ComboBox
                                x:Name="CultureSelector"
                                DisplayMemberPath="Value"
                                ItemsSource="{Binding MainViewModel.UICultures}"
                                SelectedValuePath="Key"
                                SelectionChanged="CultureSelector_SelectionChanged" />

                        </StackPanel>

                        <StackPanel Margin="0,4" Orientation="Horizontal">
                            <Label Width="100" Content="Tema da Interface" />
                            <ComboBox
                                x:Name="ThemeSelector"
                                DisplayMemberPath="Value"
                                ItemsSource="{Binding MainViewModel.UIThemes}"
                                SelectedValuePath="Key"
                                SelectionChanged="ThemeSelector_Selected" />

                        </StackPanel>

                        <StackPanel Margin="0,4" Orientation="Horizontal">
                            <Label Width="100" Content="Tamanho do Texto/Interface" />
                            <Controls:NumericUpDown
                                x:Name="UIScaling"
                                Width="100"
                                Interval="0.1"
                                Maximum="2"
                                Minimum="1"
                                NumericInputMode="Decimal"
                                Value="{Binding MainViewModel.UIScaleFactor}" />

                        </StackPanel>

                        <StackPanel Margin="0,8">
                            <CheckBox
                                x:Name="EnableTelematicsCheckbox"
                                Content="{x:Static res:SR.Settings_EnableTelemetry}"
                                IsChecked="{Binding Prefs.EnableAppTelematics}" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SubheadingWithMargin}">Recursos Experimentais</TextBlock>
                        <local:Experiments />
                    </StackPanel>
                </TabItem>
                <TabItem
                    Height="32"
                    MinWidth="140"
                    Controls:HeaderedControlHelper.HeaderFontSize="12"
                    Header="Hub de Gerenciamento">
                    <StackPanel Margin="16,0,0,0">
                        <local:ManagementHub />
                    </StackPanel>
                </TabItem>
            </TabControl>

        </DockPanel>
    </ScrollViewer>

</UserControl>
